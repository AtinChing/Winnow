{
  "manifest_version": 3,
  "name": "Winnow",
  "version": "1.0.0",
  "description": "Filter toxic and spam messages in live chat on sites you choose.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background/service-worker.js", "type": "module" },
  "action": { "default_title": "Winnow", "default_popup": "popup.html" },
  "options_page": "options.html",
  "content_scripts": [{ "matches": ["<all_urls>"], "js": ["content/content.js"], "run_at": "document_idle" }]
}
